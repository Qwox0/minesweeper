    COMPRESSED_DXT3_RGBA = 16,
    COMPRESSED_DXT5_RGBA = 17,
    COMPRESSED_ETC1_RGB = 18,
    COMPRESSED_ETC2_RGB = 19,
    COMPRESSED_ETC2_EAC_RGBA = 20,
    COMPRESSED_PVRT_RGB = 21,
    COMPRESSED_PVRT_RGBA = 22,
    COMPRESSED_ASTC_4x4_RGBA = 23,
    COMPRESSED_ASTC_8x8_RGBA = 24,
};
TextureFilter :: enum {
    POINT = 0.as(i32),
    BILINEAR = 1,
    TRILINEAR = 2,
    ANISOTROPIC_4X = 3,
    ANISOTROPIC_8X = 4,
    ANISOTROPIC_16X = 5,
};
TextureWrap :: enum {
    REPEAT = 0.as(i32),
    CLAMP = 1,
    MIRROR_REPEAT = 2,
    MIRROR_CLAMP = 3,
};
CubemapLayout :: enum {
    AUTO_DETECT = 0.as(i32),
    LINE_VERTICAL = 1,
    LINE_HORIZONTAL = 2,
    CROSS_THREE_BY_FOUR = 3,
    CROSS_FOUR_BY_THREE = 4,
};
FontType :: enum {
    DEFAULT = 0.as(i32),
    BITMAP = 1,
    SDF = 2,
};
BlendMode :: enum {
    ALPHA = 0.as(i32),
    ADDITIVE = 1,
    MULTIPLIED = 2,
    ADD_COLORS = 3,
    SUBTRACT_COLORS = 4,
    ALPHA_PREMULTIPLY = 5,
    CUSTOM = 6,
    CUSTOM_SEPARATE = 7,
};
Gesture :: enum {
    NONE = 0.as(i32),
    TAP = 1,
    DOUBLETAP = 2,
    HOLD = 4,
    DRAG = 8,
    SWIPE_RIGHT = 16,
    SWIPE_LEFT = 32,
    SWIPE_UP = 64,
    SWIPE_DOWN = 128,
    PINCH_IN = 256,
    PINCH_OUT = 512,
};
CameraMode :: enum {
    CUSTOM = 0.as(i32),
    FREE = 1,
    ORBITAL = 2,
    FIRST_PERSON = 3,
    THIRD_PERSON = 4,
};
CameraProjection :: enum {
    PERSPECTIVE = 0.as(i32),
    ORTHOGRAPHIC = 1,
};
NPatchLayout :: enum {
    NINE_PATCH = 0.as(i32),
    THREE_PATCH_VERTICAL = 1,
    THREE_PATCH_HORIZONTAL = 2,
};
TraceLogCallback :: *(_0: i32, _1: ?*u8, _2: va_list) -> void;
LoadFileDataCallback :: *(_0: ?*u8, _1: ?*mut i32) -> ?*mut u8;
SaveFileDataCallback :: *(_0: ?*u8, _1: ?*mut any, _2: i32) -> bool;
LoadFileTextCallback :: *(_0: ?*u8) -> ?*mut u8;
SaveFileTextCallback :: *(_0: ?*u8, _1: ?*u8) -> bool;

